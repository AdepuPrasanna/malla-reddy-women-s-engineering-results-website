# Backend (Render)
PORT=10000
ALLOWED_ORIGINS=https://your-app.vercel.app
PYTHONUNBUFFERED=1

# Firebase Firestore cache (optional — without these, API scrapes every time)
# Project: malla-reddy-results-webs-ec93d
# Paste the full service account JSON as a single line:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"malla-reddy-results-webs-ec93d",...}
#
# Or mount a file path (local dev):
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Set true to scrape synchronously on every cached hit and return fresh data when changed
# Default false: return cache immediately, refresh in background if portal data changed
FIREBASE_SYNC_REFRESH=false

# Admin panel (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=mrecw@admin
ADMIN_SECRET=change-this-to-a-long-random-secret
